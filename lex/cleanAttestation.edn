[{:db/id -1, :cleanAttestation/lexicon 1, :cleanAttestation/id "com.etzhayyim.madomori.cleanAttestation", :cleanAttestation/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"passId\" \"facilityId\" \"faceId\" \"robotId\" \"panesCleaned\" \"windPermitted\" \"adhesionSafe\"], :properties {:windPermitted {:type \"boolean\", :description \"wind envelope permitted the descent (G5 — false ⇒ no pass)\"}, :agentMl {:type \"number\", :description \"cleaning-agent consumed (mL) — minimized per G2\"}, :peakWindMps {:type \"number\", :description \"peak wind (speed or gust) during the pass (m/s)\"}, :robotMode {:type \"string\", :description \"suction (façade-climbing) | bmu (rope/cradle)\"}, :requiredFos {:type \"number\", :description \"required factor-of-safety on adhesion (G7)\"}, :robotId {:type \"string\", :description \"façade-cleaning unit DID performing the pass\"}, :windStopThresholdMps {:type \"number\", :description \"work-stop threshold (m/s) — pass refused at/above it (G5)\"}, :faceId {:type \"string\", :description \"façade elevation id\"}, :facilityId {:type \"string\", :description \"building id\"}, :panesCleaned {:type \"integer\", :description \"count of panes covered in this pass\"}, :pathLengthM {:type \"number\", :description \"traversed coverage path length (m)\"}, :coverageComplete {:type \"boolean\", :description \"every pane in the planned grid visited exactly once\"}, :adhesionFos {:type \"number\", :description \"achieved suction/adhesion factor-of-safety\"}, :adhesionSafe {:type \"boolean\", :description \"adhesion margin met the required factor (G7 — false ⇒ no pass)\"}, :swayAmplitudeM {:type \"number\", :description \"modeled rope/BMU sway amplitude at peak wind (m)\"}, :imageryOnDevice {:type \"boolean\", :description \"imagery processed on-device only; never transmitted (G3 — always true)\"}, :waterL {:type \"number\", :description \"water consumed (L) — minimized per G2\"}, :independentAnchors {:type \"integer\", :description \"count of independent fall-arrest anchors (≥2 required, G5)\"}, :timestamp {:type \"string\", :description \"ISO-8601 attestation time\"}, :surface {:type \"string\", :description \"glass | stone | metal (drives adhesion factor-of-safety)\"}, :passId {:type \"string\", :description \"unique cleaning-pass identifier\"}}}}}"}]
